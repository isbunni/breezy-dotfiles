#!/usr/bin/env bash
# theme — unified theme switcher for nvim + kitty + starship
# Usage: theme [gruvbox|onedark|tokyonight|catppuccin|list|cycle]
#
# Single source of truth: ~/.config/themes/<name>.toml
# Swaps starship preset, kitty colors, nvim colorscheme.

set -euo pipefail

STARSHIP_PRESETS="$HOME/.config/starship-presets"
KITTY_CONF="$HOME/.config/kitty/kitty.conf"
LUA_THEME="$HOME/.config/nvim/lua/b/theme.lua"
STATE_FILE="$HOME/.config/.theme-state"

THEMES=(gruvbox onedark tokyonight catppuccin)

# --- Kitty color blocks (from ~/.config/themes/<name>.toml [kitty] section) ---

kitty_gruvbox='
