color14 #94e2d5
color7 #bac2de
color15 #cdd6f4
url_color #94e2d5
active_border_color #89b4fa
inactive_border_color #585b70
bell_border_color #f9e2af'

# --- Nvim colorschemes ---

declare -A NVIM_CS=(
  [gruvbox]="gruvbox"
  [onedark]="onedark"
  [tokyonight]="tokyonight"
  [catppuccin]="catppuccin"
)

# --- Helpers ---

current_theme() {
  [[ -f "$STATE_FILE" ]] && cat "$STATE_FILE" || echo "gruvbox"
}

next_theme() {
  local cur idx
  cur=$(current_theme)
  for i in "${!THEMES[@]}"; do
    [[ "${THEMES[$i]}" == "$cur" ]] && idx=$(( (i + 1) % ${#THEMES[@]} )) && echo "${THEMES[$idx]}" && return
  done
  echo "gruvbox"
}

list_themes() {
  local cur; cur=$(current_theme)
  for t in "${THEMES[@]}"; do
    [[ "$t" == "$cur" ]] && echo "  ★ $t (active)" || echo "    $t"
  done
}

kitty_block() {
  local name="$1" var="kitty_${name}[@]"
  echo "${!var}"
}

apply_kitty() {
  local name="$1"
  local block; block=$(kitty_block "$name")

  if grep -q "^# BEGIN_THEME" "$KITTY_CONF"; then
    awk -v block="$block" '
      /^# BEGIN_THEME/{skip=1; print "# BEGIN_THEME"; print block; next}
      /^# END_THEME/{skip=0; print; next}
      !skip{print}
    ' "$KITTY_CONF" > "${KITTY_CONF}.tmp" && mv "${KITTY_CONF}.tmp" "$KITTY_CONF"
  else
    {
      echo "# BEGIN_THEME — managed by theme switcher, do not edit"
      echo "$block"
      echo "# END_THEME"
      echo ""
      cat "$KITTY_CONF"
    } > "${KITTY_CONF}.tmp" && mv "${KITTY_CONF}.tmp" "$KITTY_CONF"
  fi
}

apply_starship() {
  local preset_file="$STARSHIP_PRESETS/$1.toml"
  [[ -f "$preset_file" ]] && cp "$preset_file" "$HOME/.config/starship.toml"
}

apply_nvim() {
  local name="$1" cs="${NVIM_CS[$1]}"
  mkdir -p "$(dirname "$LUA_THEME")"
  cat > "$LUA_THEME" <<EOF
-- Auto-generated by theme switcher. Do not edit.
vim.g.theme = "${name}"
vim.cmd("colorscheme ${cs}")
EOF
}

save_state() { echo "$1" > "$STATE_FILE"; }

# --- Main ---

cmd="${1:-list}"

case "$cmd" in
  gruvbox|onedark|tokyonight|catppuccin)
    echo "Applying theme: $cmd"
    apply_kitty "$cmd"
    apply_starship "$cmd"
    apply_nvim "$cmd"
    save_state "$cmd"
    echo "✓ Theme set to $cmd"
    echo "  • kitty:     restart to apply"
    echo "  • starship: open new terminal tab"
    echo "  • nvim:     next session"
    ;;
  cycle)
    name=$(next_theme)
    echo "Cycling to: $name"
    apply_kitty "$name"
    apply_starship "$name"
    apply_nvim "$name"
    save_state "$name"
    echo "✓ Theme cycled to $name"
    ;;
  list|*)
    echo "Available themes:"
    list_themes
    echo ""
    echo "Usage: theme <name> | theme cycle | theme list"
    ;;
esac
