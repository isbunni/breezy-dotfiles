{
  "name": "AutoAuth",
  "keywords": [
    { "pattern": "autoauth", "weight": 5, "is_regex": false },
    { "pattern": "AutoAuth.com", "weight": 4, "is_regex": false }
  ],
  "context": {
    "domains": {
      "AutoAuth.com": "AutoAuth"
    }
  },
  "invoice_extraction": {
    "patterns": [
      "Order\\s*#\\s*([\\w-]+)",
      "Order\\s+Number\\s*:?\\s*([\\w-]+)"
    ],
    "validation_regex": "^[\\w-]+$"
  },
  "file_naming": {
    "normal_template": "{vendor}_{invoice}.pdf",
    "unknown_template": "{vendor}_UNKNOWN_{date}_{time}.pdf"
  },
  "default_subtype": "Invoice"
}
