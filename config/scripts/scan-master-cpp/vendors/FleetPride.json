{
  "name": "FleetPride",
  "keywords": [
    { "pattern": "fleetpride", "weight": 3, "is_regex": false },
    { "pattern": "FleetPride", "weight": 3, "is_regex": false }
  ],
  "context": {
    "domains": {
      "fleetpride.com": "FleetPride"
    }
  },
  "invoice_extraction": {
    "patterns": [
      "INVOICE NUMBER\\s*(\\d+)",
      "Invoice\\s+(?:Number|No|#)\\s*:?\\s*(\\d+)"
    ],
    "validation_regex": "^[0-9]{8,12}$"
  },
  "file_naming": {
    "normal_template": "{vendor}_{invoice}.pdf",
    "unknown_template": "{vendor}_UNKNOWN_{date}_{time}.pdf"
  },
  "default_subtype": "Invoice"
}
