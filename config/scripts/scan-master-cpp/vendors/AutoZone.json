{
  "name": "AutoZone",
  "keywords": [
    { "pattern": "autozone", "weight": 3, "is_regex": false },
    { "pattern": "autozonepro", "weight": 3, "is_regex": false },
    { "pattern": "AutoZonePro.com", "weight": 2, "is_regex": false },
    { "pattern": "Commercial Invoice", "weight": 1, "is_regex": false },
    { "pattern": "Commercial Return", "weight": 1, "is_regex": false },
    { "pattern": "\\b0222[0-9]\\b", "weight": 2, "is_regex": true },
    { "pattern": "\\b0223[0-9]\\b", "weight": 2, "is_regex": true }
  ],
  "context": {
    "phones": {
      "503-371-1648": "AutoZone",
      "503-315-9834": "AutoZone"
    },
    "domains": {
      "autozonepro.com": "AutoZone"
    }
  },
  "invoice_extraction": {
    "patterns": [
      "Invoice\\s+Number\\s*:\\s*(0\\d{10})",
      "Invoice\\s+Number\\s+1?\\s*(0\\d{10})",
      "Invoice\\s+Number\\s*[^0-9]*\\s*1?\\s*(0\\d{10})"
    ],
    "validation_regex": "^022[0-9]{8}$"
  },
  "file_naming": {
    "normal_template": "{vendor}_{subtype}_{invoice}.pdf",
    "unknown_template": "{vendor}_UNKNOWN_{date}_{time}.pdf"
  },
  "default_subtype": "Invoice"
}
