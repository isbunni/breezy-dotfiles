{
  "name": "OReilly",
  "keywords": [
    { "pattern": "o'reilly", "weight": 3, "is_regex": false },
    { "pattern": "oreilly", "weight": 3, "is_regex": false },
    { "pattern": "O'Reilly Auto Parts", "weight": 3, "is_regex": false }
  ],
  "context": {
    "domains": {
      "oreillypro.com": "OReilly"
    }
  },
  "invoice_extraction": {
    "patterns": [
      "Invoice\\s+([\\d-]+)",
      "Invoice\\s*#?\\s*([\\d-]+)"
    ],
    "validation_regex": "^[0-9]{4}-[0-9]{5,7}$"
  },
  "file_naming": {
    "normal_template": "{vendor}_{invoice}.pdf",
    "unknown_template": "{vendor}_UNKNOWN_{date}_{time}.pdf"
  },
  "default_subtype": "Invoice"
}
