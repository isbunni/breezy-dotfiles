{
  "name": "DOT",
  "keywords": [
    { "pattern": "dot.*inspection|vehicle.*inspection", "weight": 3, "is_regex": true },
    { "pattern": "oregon.*dot", "weight": 2, "is_regex": true },
    { "pattern": "inspection.*report|vehicle.*inspection.*report", "weight": 2, "is_regex": true }
  ],
  "invoice_extraction": {
    "patterns": [
      "(RO|Report|Invoice)\\s*(Number|#|No)\\s*:?\\s*([\\w-]+)"
    ],
    "validation_regex": "^[\\w-]+$"
  },
  "file_naming": {
    "normal_template": "{vendor}_{invoice}.pdf",
    "unknown_template": "{vendor}_{date}_{time}.pdf"
  },
  "default_subtype": "Inspection"
}
