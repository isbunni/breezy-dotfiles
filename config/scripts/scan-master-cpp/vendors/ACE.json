{
  "name": "ACE",
  "keywords": [
    { "pattern": "ace.*freight|harbor.*freight|ace.*truck", "weight": 3, "is_regex": true },
    { "pattern": "ace.*supply|ace.*parts", "weight": 2, "is_regex": true }
  ],
  "invoice_extraction": {
    "patterns": [
      "Invoice\\s+(?:Number|#|No)\\s*:?\\s*([\\w-]+)"
    ],
    "validation_regex": "^[\\w-]+$"
  },
  "file_naming": {
    "normal_template": "{vendor}_{invoice}.pdf",
    "unknown_template": "{vendor}_UNKNOWN_{date}_{time}.pdf"
  },
  "default_subtype": "Invoice"
}
