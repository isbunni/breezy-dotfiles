{
  "name": "JohnstoneSupply",
  "keywords": [
    { "pattern": "johnstone", "weight": 4, "is_regex": false },
    { "pattern": "johnstone.*supply", "weight": 3, "is_regex": true },
    { "pattern": "3080.*22ND", "weight": 2, "is_regex": true },
    { "pattern": "97302", "weight": 1, "is_regex": false }
  ],
  "context": {
    "domains": {
      "johnstonesupply.com": "JohnstoneSupply"
    },
    "addresses": {
      "3080 22ND ST": "JohnstoneSupply"
    }
  },
  "invoice_extraction": {
    "patterns": [
      "Invoice\\s+(?:Number|#|No)\\s*:?\\s*(\\d+)",
      "Invoice\\s+(?:Number|#|No)\\s*:?\\s*([\\w-]+)"
    ],
    "validation_regex": "^[0-9]{4,8}$"
  },
  "file_naming": {
    "normal_template": "{vendor}_{invoice}.pdf",
    "unknown_template": "{vendor}_UNKNOWN_{date}_{time}.pdf"
  },
  "default_subtype": "Invoice"
}
